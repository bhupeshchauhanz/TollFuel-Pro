<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:ignore="Overdraw"
    android:background="@color/tr_bg_dark"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header / Branding -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/tr_accent_green"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

    <!-- Route Card -->
    <LinearLayout
        android:id="@+id/card_route"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_18dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_dot"
                app:tint="@color/tr_accent_green" />
                
            <TextView
                android:id="@+id/tv_source"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                tools:text="Source City"
                android:textColor="@color/tr_accent_green"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:breakStrategy="high_quality" />
                
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_arrow_right"
                app:tint="@color/text_secondary" />
                
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_location_pin"
                app:tint="@color/tr_accent_red" />
                
            <TextView
                android:id="@+id/tv_destination"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                tools:text="Destination City"
                android:textColor="@color/tr_accent_red"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:breakStrategy="high_quality" />
        </LinearLayout>

        <!-- Meta Chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_vehicle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:backgroundTint="#2A32D583"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                tools:text="Car"
                android:textColor="@color/tr_accent_green"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chip_trip_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:backgroundTint="#1F2A38"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                tools:text="One Way"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chip_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:backgroundTint="#1F2A38"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                tools:text="0 km"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/chip_fuel_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:backgroundTint="#2A1F38"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/petrol"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Total Cost Card -->
    <LinearLayout
        android:id="@+id/card_total_cost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_22dp_glow"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/total_trip_cost"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_total_cost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            tools:text="₹0"
            android:textColor="@color/tr_accent_green"
            android:textSize="42sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Cost Breakdown Row -->
    <LinearLayout
        android:id="@+id/card_costs_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:baselineAligned="false">

        <!-- Toll Cost -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="7dp"
            android:background="@drawable/bg_card_18dp"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_wallet"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/toll_cost"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_toll_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                tools:text="₹0"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Fuel Cost -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="7dp"
            android:background="@drawable/bg_card_18dp"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_fuel_drop"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/fuel_cost"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_fuel_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                tools:text="₹0"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Fuel Details Card -->
    <LinearLayout
        android:id="@+id/card_fuel_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_18dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:id="@+id/layout_mileage_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/mileage"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_mileage_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="0 km/l"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1F2A38"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/layout_fuel_price_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/fuel_price_text"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_fuel_price_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="0 ₹/l"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1F2A38"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/fuel_needed_text"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_fuel_needed_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="0 litres"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/tv_plazas_highlight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glow_badge_green"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            tools:text="3 Toll Plazas on Your Route"
            android:textColor="@color/tr_accent_green"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Toll List container (Populated dynamically) -->
    <LinearLayout
        android:id="@+id/ll_toll_plazas_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp" />
        
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/generated_by_app"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="16dp" />

</LinearLayout>
