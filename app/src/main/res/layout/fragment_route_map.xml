<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/bg_primary">

    <!-- WebView to display map -->
    <WebView
        android:id="@+id/webview_map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Native empty state layout -->
    <LinearLayout
        android:id="@+id/layout_empty_map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="visible">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_navigation"
            app:tint="@color/accent"
            android:alpha="0.8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="No Route Calculated"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Calculate a trip route first to view it on the interactive map with toll plazas, fuel stations, and EV chargers."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_calc_trip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Calculate Trip"
            android:textColor="@color/bg_primary"
            android:textAllCaps="false"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:background="@drawable/bg_button_teal" />
    </LinearLayout>

    <!-- Header Floating Card (Back button and title) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_map_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardElevation="8dp"
        android:visibility="gone">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:id="@+id/btn_map_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_right"
                android:rotation="180"
                app:tint="@color/text_primary"
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/tv_map_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/btn_map_back"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:text="Route Map"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom Floating Card (Trip Details Overview) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_trip_overview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardElevation="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Route name -->
            <TextView
                android:id="@+id/tv_overview_route"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mumbai → Pune"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Subtitle details -->
            <TextView
                android:id="@+id/tv_overview_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Car/Jeep/Van • One Way"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Stats grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="1">

                <!-- Total Cost -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Cost"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true" />
                    <TextView
                        android:id="@+id/tv_overview_total_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="₹1,250"
                        android:textColor="@color/accent"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Distance -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distance"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true" />
                    <TextView
                        android:id="@+id/tv_overview_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="148 km"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Toll Plazas -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toll Plazas"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true" />
                    <TextView
                        android:id="@+id/tv_overview_tolls"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="3 Plazas"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </GridLayout>

            <!-- Bottom sheet action/details button -->
            <Button
                android:id="@+id/btn_overview_details"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_trip_type_selected"
                android:text="View Detailed Breakdown"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:padding="0dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>
